{
  "name": "rss-angular-components",
  "version": "0.0.1",
  "author": "Rodrigo S. Santos",
  "license": "MIT",
  "homepage": "https://github.com/rodrigossbr/rss-angular-components#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigossbr/rss-angular-components.git"
  },
  "bugs": {
    "url": "https://github.com/rodrigossbr/rss-angular-components/issues"
  },
  "description": "Monorepo de componentes e bibliotecas Angular de alta performance, incluindo gerenciamento de estado e integração com Keycloak.",
  "keywords": [
    "angular",
    "monorepo",
    "nx",
    "state-management",
    "keycloak-angular",
    "sso",
    "typescript-library",
    "reactive-programming",
    "rssbr",
    "design-system",
    "infrastructure"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:lib:rss-state-store": "ng build rss-state-store",
    "publish:lib:rss-state-store": "npm run update-readme:lib:rss-state-store && npm run build:lib:rss-state-store && cd dist/rss-state-store && npm publish --access public --provenance --registry=https://registry.npmjs.org/",
    "test:lib:rss-state-store": "vitest run --project rss-state-store",
    "test:lib:watch:rss-state-store": "vitest --project rss-state-store",
    "update-readme:lib:rss-state-store": "node scripts/update-readme-version.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
